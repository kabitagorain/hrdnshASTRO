---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  ogType?: "website" | "business.business" | "profile" | "article";
  schemaType?: "person" | "service" | "legal" | "none";
  noindex?: boolean;
  customJsonLd?: object[];
  datePublished?: string;
  dateModified?: string;
}

import "@styles/global.css";
import FloatingButton from "@components/FloatingButton.astro";
import TosConsent from "@components/TosConsent.astro";
import HrdnshBrand from "@components/HrdnshBrand.astro";
import { profile, siteData } from "@data/services";

const {
  title,
  description = siteData.defaultDescription,
  ogImage = siteData.defaultOgImage,
  canonicalURL = new URL(
    Astro.url.pathname.replace(/\/+$/, "") || "/",
    Astro.site || siteData.url,
  ).href,
  ogType = "website",
  schemaType = "service",
  noindex = false,
  customJsonLd = [],
  datePublished = undefined,
  dateModified = undefined,
} = Astro.props;

// Initialize isolated Schema Graph Array
const jsonLdBlocks: object[] = [...customJsonLd];

if (schemaType === "person" || schemaType === "service") {
  jsonLdBlocks.push({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteData.url}#person`,
    name: profile.name,
    url: siteData.url,
    jobTitle: profile.title,
    email: profile.email,
    telephone: profile.phone,
    image: `${siteData.url}/avatar.png`,
    sameAs: [
      profile.upwork,
      "https://github.com/haradhansharma",
      "https://linkedin.com/in/haradhan-sharma",
    ],
    knowsAbout: siteData.serviceTypes,
    worksFor: {
      "@type": "Organization",
      name: siteData.brandName,
      url: siteData.url,
    },
  });
}

if (schemaType === "service") {
  jsonLdBlocks.push({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${siteData.url}#service`,
    name: siteData.siteName,
    description: siteData.defaultDescription,
    url: siteData.url,
    image: `${siteData.url}${siteData.defaultOgImage}`,
    provider: {
      "@type": "Person",
      "@id": `${siteData.url}#person`,
    },
    serviceType: siteData.serviceTypes,
    areaServed: "Worldwide",
  });
}

if (schemaType === "legal") {
  jsonLdBlocks.push({
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description: description,
    url: canonicalURL,
    isPartOf: {
      "@type": "WebSite",
      "@id": `${siteData.url}#website`,
    },
  });
}

if (schemaType === "person") {
  jsonLdBlocks.push({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteData.url}#website`,
    name: siteData.siteName,
    url: siteData.url,
    description: siteData.defaultDescription,
    publisher: {
      "@type": "Person",
      "@id": `${siteData.url}#person`,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${siteData.url}/services?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  });
}

// Compute safe dynamic metadata strings
const absoluteOgImageUrl = new URL(ogImage, Astro.site || siteData.url).href;
---

<!doctype html>
<html
  lang="en"
  class="scroll-smooth"
  x-data="{ theme: localStorage.getItem('theme') || 'dark' }"
  x-init="$watch('theme', v => { localStorage.setItem('theme', v); document.documentElement.classList.toggle('light', v === 'light'); }); if(theme === 'light') document.documentElement.classList.add('light')"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    {
      datePublished && (
        <meta property="article:published_time" content={datePublished} />
      )
    }
    {
      dateModified && (
        <meta property="article:modified_time" content={dateModified} />
      )
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteData.siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:alt" content={title} />

    <meta property="profile:first_name" content="Haradhan" />
    <meta property="profile:last_name" content="Sharma" />
    <meta property="profile:username" content="haradhansharma" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImageUrl} />

    <!-- Performance Optimization: Core Font Pre-connections -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
      fetchpriority="high"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
      fetchpriority="high"
    />

    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      />
    </noscript>

    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" sizes="48x48" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/avatar.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/avatar.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/avatar.png" />

    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0e1a" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Emit structural data graphs -->
    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <!-- Inline script to prevent layout theme flash -->
    <script is:inline>
      if (localStorage.getItem("theme") === "light") {
        document.documentElement.classList.add("light");
      }
    </script>
  </head>
  <body class="min-h-screen antialiased transition-colors duration-300">
    <script is:inline>
      document.addEventListener("alpine:init", function () {
        Alpine.store("catalogModal", { open: false, submitted: false });
      });
    </script>

    <slot />

    <FloatingButton />
    <TosConsent />
    <HrdnshBrand />

    <!-- Core Interactive Animation Observers -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("animate-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll(".animate-on-scroll")
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
