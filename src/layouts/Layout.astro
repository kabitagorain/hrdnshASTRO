---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schemaType?: 'person' | 'service' | 'legal' | 'none';
  noindex?: boolean;
  customJsonLd?: object[];
}

import '@styles/global.css';
import FloatingButton from '@components/FloatingButton.astro';
import TosConsent from '@components/TosConsent.astro';
import { profile, siteData } from '@data/services';

const {
  title,
  description = siteData.defaultDescription,
  ogImage = siteData.defaultOgImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  schemaType = 'service',
  noindex = false,
  customJsonLd = [],
} = Astro.props;

// Build JSON-LD based on page type
const jsonLdBlocks: object[] = [...customJsonLd];

// Person schema — for homepage, resume, and about
if (schemaType === 'person' || schemaType === 'service') {
  jsonLdBlocks.push({
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': siteData.url + '#person',
    name: profile.name,
    url: siteData.url,
    jobTitle: profile.title,
    email: profile.email,
    telephone: profile.phone,
    image: siteData.url + '/avatar.png',
    sameAs: [
      profile.upwork,
    ],
    knowsAbout: siteData.serviceTypes,
    worksFor: {
      '@type': 'Organization',
      name: siteData.brandName,
      url: siteData.url,
    },
  });
}

// ProfessionalService schema — for service and pricing pages
if (schemaType === 'service') {
  jsonLdBlocks.push({
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    '@id': siteData.url + '#service',
    name: siteData.siteName,
    description: siteData.defaultDescription,
    url: siteData.url,
    image: siteData.url + siteData.defaultOgImage,
    provider: {
      '@type': 'Person',
      '@id': siteData.url + '#person',
    },
    serviceType: siteData.serviceTypes,
    areaServed: 'Worldwide',
  });
}

// WebPage schema — for legal pages
if (schemaType === 'legal') {
  jsonLdBlocks.push({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description: description,
    url: canonicalURL,
    isPartOf: {
      '@type': 'WebSite',
      '@id': siteData.url + '#website',
    },
  });
}

// WebSite schema — emitted on homepage
if (schemaType === 'person') {
  jsonLdBlocks.push({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': siteData.url + '#website',
    name: siteData.siteName,
    url: siteData.url,
    description: siteData.defaultDescription,
    publisher: {
      '@type': 'Person',
      '@id': siteData.url + '#person',
    },
  });
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth" x-data="{ theme: localStorage.getItem('theme') || 'dark' }" x-init="$watch('theme', v => { localStorage.setItem('theme', v); document.documentElement.classList.toggle('light', v === 'light'); }); if(theme === 'light') document.documentElement.classList.add('light')">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteData.siteName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Preconnect: Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin fetchpriority="high" />
    <!-- Async Google Fonts — loads without blocking render -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" />
    </noscript>

    <!-- Preconnect: Alpine.js CDN -->
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    <!-- Favicon & Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/avatar.png" />

    <!-- Web Manifest -->
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0e1a" />

    <!-- Preload hero background (above the fold — LCP image) -->
    <link rel="preload" href="/hero-bg.jpg" as="image" fetchpriority="high" />

    <!-- Sitemap link -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD Structured Data -->
    {jsonLdBlocks.map((block) => (
      <script is:inline set:html={JSON.stringify(block)} />
    ))}

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body class="min-h-screen antialiased transition-colors duration-300">
    <script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <slot />
    <FloatingButton />
    <TosConsent />

    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
    </script>

    <!-- mautic -->
    <script is:inline>
      (function(w,d,t,u,n,a,m){w['MauticTrackingObject']=n;
          w[n]=w[n]||function(){(w[n].q=w[n].q||[]).push(arguments)},a=d.createElement(t),
          m=d.getElementsByTagName(t)[0];a.async=1;a.src=u;m.parentNode.insertBefore(a,m)
      })(window,document,'script','https://crm.healthforyou.nl/mtc.js','mt');

      mt('send', 'pageview');
  </script>
  <!-- mautic -->
  </body>
</html>
