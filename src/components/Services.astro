---
import { services } from '../data/services';
---

<section id="services" class="relative py-24 sm:py-32 dark-section noise-overlay">
  <div class="absolute inset-0 dot-pattern"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20 animate-on-scroll">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow">
        <span class="text-sm font-semibold text-accent-400">What I Offer</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
        <span class="text-surface-100">Services crafted for</span><br />
        <span class="gradient-text">real results</span>
      </h2>
      <p class="mt-6 text-lg text-surface-400 leading-relaxed">
        Each service is designed to deliver measurable impact — whether you're a business owner looking to grow or a developer needing expert engineering.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <a
          href={`/services/${service.id}`}
          class="animate-on-scroll group glass-card glass-card-hover rounded-2xl p-6 sm:p-8 relative overflow-hidden"
        >
          <!-- Hover shimmer -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"></div>
          </div>

          <div class="relative z-10">
            <!-- Top row -->
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500/20 to-accent-500/20 text-2xl border border-primary-500/10 transition-transform group-hover:scale-110">
                {service.icon}
              </div>
              <span class="text-xs font-bold text-surface-600 tracking-widest font-mono">{service.number}</span>
            </div>

            <!-- Title -->
            <h3 class="text-xl font-bold text-surface-100 mb-3 group-hover:text-primary-300 transition-colors">
              {service.title}
            </h3>

            <!-- Tagline -->
            <p class="text-surface-400 text-sm leading-relaxed mb-6">
              {service.tagline}
            </p>

            <!-- Business preview -->
            <div class="p-4 rounded-xl bg-white/[0.03] border border-surface-600/10 mb-6">
              <p class="text-xs font-semibold text-accent-400 uppercase tracking-wider mb-2">For Business Owners</p>
              <p class="text-sm text-surface-300 leading-relaxed line-clamp-3">
                {service.businessOwner.summary}
              </p>
            </div>

            <!-- Bottom row: Price + Arrow -->
            <div class="flex items-center justify-between pt-4 border-t border-surface-600/15">
              <div>
                <span class="text-xs text-surface-500">Starting from</span>
                <div class="text-xl font-black text-surface-100">${service.pricing.oneTime}</div>
              </div>
              <div class="flex items-center gap-1.5 text-sm font-semibold text-primary-400 group-hover:gap-2.5 transition-all">
                Details
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
