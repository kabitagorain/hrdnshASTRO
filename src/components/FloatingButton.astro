---
import { siteData } from '@data/services';
---

<div
  x-data="{ open: false, tooltip: true }"
  x-init="setTimeout(() => tooltip = false, 3000)"
  class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3"
>
  <!-- Tooltip hint (shows for 3 seconds on load) -->
  <div
    x-show="tooltip && !open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-2"
    class="glass-card rounded-xl px-4 py-2.5 text-sm text-surface-200 max-w-[200px] shadow-xl"
  >
    💬 Need help? Send a message!
  </div>

  <!-- Action buttons (expand up) -->
  <div class="flex flex-col items-end gap-3">
    <!-- WhatsApp -->
    <a
      x-show="open"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 translate-y-4 scale-75"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 scale-75"
      href={`https://wa.me/${siteData.whatsapp}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 glass-card rounded-xl pr-4 pl-3 py-3 shadow-xl hover:border-success-400/30 transition-all group"
    >
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-success-400/15 text-success-400 group-hover:bg-success-400/25 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </div>
      <div>
        <div class="text-sm font-semibold text-surface-200">WhatsApp</div>
        <div class="text-xs text-surface-500">Quick reply</div>
      </div>
    </a>

    <!-- Email -->
    <a
      x-show="open"
      x-transition:enter="transition ease-out duration-200 delay-75"
      x-transition:enter-start="opacity-0 translate-y-4 scale-75"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 scale-75"
      href={`mailto:${siteData.email}`}
      class="flex items-center gap-3 glass-card rounded-xl pr-4 pl-3 py-3 shadow-xl hover:border-primary-400/30 transition-all group"
    >
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500/15 text-primary-400 group-hover:bg-primary-500/25 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <div class="text-sm font-semibold text-surface-200">Email</div>
        <div class="text-xs text-surface-500">Detailed inquiry</div>
      </div>
    </a>

    <!-- Upwork -->
    <a
      x-show="open"
      x-transition:enter="transition ease-out duration-200 delay-150"
      x-transition:enter-start="opacity-0 translate-y-4 scale-75"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 scale-75"
      href={siteData.upwork}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 glass-card rounded-xl pr-4 pl-3 py-3 shadow-xl hover:border-success-400/30 transition-all group"
    >
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-success-400/15 text-success-400 group-hover:bg-success-400/25 transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
        </svg>
      </div>
      <div>
        <div class="text-sm font-semibold text-surface-200">Upwork</div>
        <div class="text-xs text-surface-500">Hire via platform</div>
      </div>
    </a>
  </div>

  <!-- Main toggle button -->
  <button
    @click="open = !open"
    class="relative flex h-14 w-14 items-center justify-center rounded-full shadow-2xl transition-all duration-300 focus:outline-none"
    :class="open ? 'bg-surface-700 rotate-0' : 'bg-green-500 hover:bg-green-400 hover:scale-110 animate-bounce'"
    style="animation-duration: 2s;"
    aria-label="Contact options"
  >
    <!-- Chat icon (closed state) -->
    <svg x-show="!open" class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <!-- Close icon (open state) -->
    <svg x-show="open" x-cloak class="w-6 h-6 text-surface-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>

    <!-- Pulse ring (closed state only) -->
    <span
      x-show="!open"
      class="absolute inset-0 rounded-full bg-green-500 animate-ping opacity-20"
    ></span>
  </button>
</div>
