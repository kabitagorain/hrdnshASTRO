---
// Contact section component
import { profile } from '../data/services';
---

<section id="contact" class="relative py-24 sm:py-32 overflow-hidden dark-section noise-overlay">
  <!-- Background glow -->
  <div class="absolute top-1/4 left-0 w-[500px] h-[500px] bg-primary-600/8 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] bg-accent-600/6 rounded-full blur-[100px]"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow animate-on-scroll">
        <span class="text-sm font-semibold text-accent-400">Let's Work Together</span>
      </div>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight animate-on-scroll">
        <span class="text-surface-100">Ready to build something</span><br />
        <span class="gradient-text">extraordinary?</span>
      </h2>

      <p class="mt-6 text-lg text-surface-400 leading-relaxed animate-on-scroll">
        Whether you have a clear project in mind or just want to explore possibilities — let's talk. I respond within 2 hours during business hours.
      </p>

      <!-- Contact Cards -->
      <div class="mt-12 grid sm:grid-cols-3 gap-4 animate-on-scroll">
        <a
          href={`mailto:${profile.email}`}
          class="group flex flex-col items-center gap-3 glass-card glass-card-hover rounded-2xl p-6"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400 group-hover:bg-primary-500/20 transition-colors border border-primary-500/10">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-surface-200">Email</span>
          <span class="text-xs text-surface-500">{profile.email}</span>
        </a>

        <a
          href={`https://wa.me/${profile.phone}`}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-3 glass-card glass-card-hover rounded-2xl p-6"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-success-400/10 text-success-400 group-hover:bg-success-400/20 transition-colors border border-success-400/10">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <span class="text-sm font-semibold text-surface-200">WhatsApp</span>
          <span class="text-xs text-surface-500">Quick response</span>
        </a>

        <a
          href={`${profile.upwork}`}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-3 glass-card glass-card-hover rounded-2xl p-6"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-success-400/10 text-success-400 group-hover:bg-success-400/20 transition-colors border border-success-400/10">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/>
            </svg>
          </div>
          <span class="text-sm font-semibold text-surface-200">Upwork</span>
          <span class="text-xs text-surface-500">Hire through platform</span>
        </a>
      </div>

      <!-- Process Steps -->
      <div class="mt-16 animate-on-scroll">
        <h3 class="text-lg font-bold text-surface-200 mb-8">How it works</h3>
        <div class="grid sm:grid-cols-3 gap-8">
          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-500/10 text-primary-400 font-bold text-sm mx-auto mb-4 border border-primary-500/15">1</div>
            <h4 class="text-sm font-bold text-surface-200 mb-2">Tell Me Your Need</h4>
            <p class="text-xs text-surface-500 leading-relaxed">Share your project requirements or business problem — even a rough idea works.</p>
          </div>
          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-500/10 text-primary-400 font-bold text-sm mx-auto mb-4 border border-primary-500/15">2</div>
            <h4 class="text-sm font-bold text-surface-200 mb-2">Get a Clear Plan</h4>
            <p class="text-xs text-surface-500 leading-relaxed">I'll outline the approach, timeline, and cost — no surprises, no hidden fees.</p>
          </div>
          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-500/10 text-primary-400 font-bold text-sm mx-auto mb-4 border border-primary-500/15">3</div>
            <h4 class="text-sm font-bold text-surface-200 mb-2">Launch & Support</h4>
            <p class="text-xs text-surface-500 leading-relaxed">I deliver, deploy, and provide ongoing support to keep everything running smoothly.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
