---
import { profile, navLinks } from '@data/services';
---

<header
  x-data="{ mobileOpen: false, moreOpen: false, scrolled: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 30 })"
  @click.outside="moreOpen = false"
  :class="scrolled ? 'glass-nav shadow-2xl shadow-black/10' : ''"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 w-full overflow-visible"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between lg:h-18 min-w-0">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <div class="avatar-ring">
          <img src="/header-avatar.svg" alt={profile.name} class="w-9 h-9 rounded-full object-cover" />
        </div>
        <span class="text-lg font-bold tracking-tight">
          <span class="text-surface-100">{profile.fname.charAt(0).toUpperCase()}</span><span class="gradient-text">{profile.lname.toLowerCase()}</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1 min-w-0">
        {navLinks.map((link) => (
          link.children ? (
            // "More" dropdown
            <div class="relative" @click.stop>
              <button
                @click="moreOpen = !moreOpen"
                class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-surface-400 rounded-lg transition-all duration-200 hover:text-surface-100 hover:bg-white/5"
                :class="moreOpen ? 'text-surface-100 bg-white/5' : ''"
                aria-haspopup="true"
                :aria-expanded="moreOpen"
              >
                {link.label}
                <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="moreOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Dropdown panel -->
              <div
                x-show="moreOpen"
                x-transition:enter="transition ease-out duration-150"
                x-transition:enter-start="opacity-0 scale-95 -translate-y-1"
                x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                x-transition:leave="transition ease-in duration-100"
                x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                x-transition:leave-end="opacity-0 scale-95 -translate-y-1"
                x-cloak
                class="absolute right-0 mt-2 w-52 rounded-xl glass-card border border-surface-600/20 shadow-xl shadow-black/20 py-1.5 z-50"
              >
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-surface-400 transition-all hover:text-surface-100 hover:bg-white/5"
                  >
                    <span>{child.label}</span>
                    {child.href.startsWith('http') && (
                      <svg class="w-3.5 h-3.5 text-surface-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            // Regular top-level link
            <a
              href={link.href}
              class="px-4 py-2 text-sm font-medium text-surface-400 rounded-lg transition-all duration-200 hover:text-surface-100 hover:bg-white/5"
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Right side: Theme toggle + CTA -->
      <div class="hidden lg:flex items-center gap-3 shrink-0">
        <!-- Dark/Light Toggle -->
        <button
          @click="$root.theme = $root.theme === 'dark' ? 'light' : 'dark'"
          class="flex items-center justify-center w-9 h-9 rounded-lg text-surface-400 hover:text-surface-200 hover:bg-white/5 transition-all"
          :title="$root.theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
        >
          <!-- Sun icon (show in dark mode) -->
          <svg x-show="$root.theme === 'dark'" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon icon (show in light mode) -->
          <svg x-show="$root.theme === 'light'" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- CTA -->
        <a
          href="#contact"
          class="btn-glow inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-500 hover:-translate-y-px"
        >
          Hire Me
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        @click="mobileOpen = !mobileOpen"
        class="lg:hidden inline-flex items-center justify-center rounded-lg p-2 text-surface-400 hover:bg-white/5 transition-colors"
        aria-label="Toggle menu"
      >
        <svg x-show="!mobileOpen" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg x-show="mobileOpen" x-cloak class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-3"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-3"
    x-cloak
    class="lg:hidden glass-nav border-t border-surface-700/30"
  >
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
      <nav class="flex flex-col gap-1">
        {navLinks.map((link) => (
          link.children ? (
            // Mobile "More" section — show children as indented items
            <div x-data="{ open: false }">
              <button
                @click="open = !open"
                class="w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-surface-400 rounded-lg transition-colors hover:text-surface-100 hover:bg-white/5"
              >
                <span>{link.label}</span>
                <svg class="w-4 h-4 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div x-show="open" x-cloak>
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    @click="mobileOpen = false"
                    class="flex items-center gap-2 pl-8 pr-4 py-2.5 text-sm text-surface-500 rounded-lg transition-colors hover:text-surface-200 hover:bg-white/5"
                  >
                    <span class="w-1 h-1 rounded-full bg-surface-600 shrink-0"></span>
                    <span>{child.label}</span>
                    {child.href.startsWith('http') && (
                      <svg class="w-3 h-3 text-surface-600 ml-auto shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            // Regular mobile link
            <a
              href={link.href}
              @click="mobileOpen = false"
              class="px-4 py-3 text-sm font-medium text-surface-400 rounded-lg transition-colors hover:text-surface-100 hover:bg-white/5"
            >
              {link.label}
            </a>
          )
        ))}
        <div class="flex items-center gap-3 mt-3 pt-3 border-t border-surface-700/30">
          <!-- Theme toggle mobile -->
          <button
            @click="$root.theme = $root.theme === 'dark' ? 'light' : 'dark'"
            class="flex items-center justify-center w-10 h-10 rounded-lg text-surface-400 hover:bg-white/5 transition-colors"
          >
            <svg x-show="$root.theme === 'dark'" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg x-show="$root.theme === 'light'" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          <a
            href="#contact"
            @click="mobileOpen = false"
            class="flex-1 inline-flex items-center justify-center gap-2 rounded-lg bg-primary-600 px-5 py-3 text-sm font-semibold text-white"
          >
            Hire Me
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>
