---
import { profile } from '../data/services';
---

<section id="about" class="relative py-24 sm:py-32 overflow-hidden" style="background: linear-gradient(180deg, #0c1220 0%, #111827 50%, #0c1220 100%);">
  <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-primary-600/5 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-accent-600/5 rounded-full blur-[100px]"></div>
  <div class="absolute inset-0 dot-pattern"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Content -->
      <div class="animate-on-scroll">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow">
          <span class="text-sm font-semibold text-accent-400">About Me</span>
        </div>

        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
          <span class="text-surface-100">Developer who</span><br />
          <span class="gradient-text">gets things done</span>
        </h2>

        <!-- Avatar + name (mobile visible) -->
        <div class="flex items-center gap-4 mt-8 mb-8 lg:hidden">
          <div class="avatar-ring">
            <img src="/haradhan-sharma.png" alt="Haradhan Sharma" class="w-16 h-16 rounded-full object-cover" />
          </div>
          <div>
            <h3 class="text-lg font-bold text-surface-100">{profile.name}</h3>
            <p class="text-sm text-surface-400">{profile.title}</p>
          </div>
        </div>

        <div class="space-y-5">
          {profile.bio.map((paragraph) => (
            <p class="text-surface-400 leading-relaxed text-base">
              {paragraph}
            </p>
          ))}
        </div>

        <!-- Info pills -->
        <div class="mt-8 flex flex-wrap gap-3">
          <div class="inline-flex items-center gap-2 rounded-full glass-card px-4 py-2.5 text-sm text-surface-300">
            <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {profile.location}
          </div>
          <div class="inline-flex items-center gap-2 rounded-full glass-card px-4 py-2.5 text-sm text-surface-300">
            <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {profile.email}
          </div>
        </div>
      </div>

      <!-- Right: Tech Stack -->
      <div class="animate-on-scroll space-y-6" style="transition-delay: 0.2s;">
        <h3 class="text-xl font-bold text-surface-100 mb-2">Tech Stack</h3>

        <div x-data="{ activeCategory: null }" class="space-y-3">
          {profile.techStack.map((category) => (
            <div>
              <button
                @click={`activeCategory = activeCategory === '${category.category}' ? null : '${category.category}'`}
                class="w-full flex items-center justify-between p-4 rounded-xl glass-card hover:border-primary-500/20 transition-all text-left group"
              >
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-primary-500/10 flex items-center justify-center">
                    <span class="text-primary-400 text-sm font-bold">{category.category.charAt(0)}</span>
                  </div>
                  <span class="text-sm font-semibold text-surface-200 group-hover:text-surface-100 transition-colors">{category.category}</span>
                </div>
                <svg
                  class="w-4 h-4 text-surface-500 transition-transform duration-200"
                  :class={`activeCategory === '${category.category}' ? 'rotate-180 text-accent-400' : ''`}"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div
                x-show={`activeCategory === '${category.category}'`}
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0 -translate-y-2"
                x-transition:enter-end="opacity-100 translate-y-0"
                x-cloak
                class="flex flex-wrap gap-2 mt-2 pl-4 pr-4 pb-3"
              >
                {category.items.map((item) => (
                  <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-surface-600/15 text-sm text-surface-300 font-mono">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
