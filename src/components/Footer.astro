---
const year = new Date().getFullYear();
import { profile, siteData, navLinks } from '../data/services';
---

<footer class="relative border-t border-surface-700/20" style="background: #070b14;">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5">
        <div class="avatar-ring">
          <img src="/avatar.png" alt={profile.name} class="w-7 h-7 rounded-full object-cover" />
        </div>
        <span class="text-sm font-bold">
          <span class="text-surface-300">{profile.fname.charAt(0).toUpperCase()}</span><span class="gradient-text">{profile.lname.toLowerCase()}</span>
          <span class="text-surface-500 font-normal ml-1">Services</span>
        </span>
      </a>

      <!-- Links -->
      <nav class="flex items-center gap-6">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm text-surface-500 hover:text-surface-300 transition-colors">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Copyright -->
      <p class="text-xs text-surface-600">
        &copy; {year} {profile.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
