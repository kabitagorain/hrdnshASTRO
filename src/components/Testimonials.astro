---
import { testimonials } from '@data/services';
---

<section id="testimonials" class="relative py-24 sm:py-32" style="background: linear-gradient(180deg, #0c1220 0%, #111827 50%, #0c1220 100%);">
  <div class="absolute inset-0 dot-pattern"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow">
        <span class="text-sm font-semibold text-accent-400">Client Results</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
        <span class="text-surface-100">Trusted by businesses</span><br />
        <span class="gradient-text">that deliver</span>
      </h2>
    </div>

    <!-- Testimonials -->
    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <div class="animate-on-scroll glass-card glass-card-hover rounded-2xl p-8 relative">
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-warning-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-surface-300 leading-relaxed mb-6 text-base italic">
            "{t.quote}"
          </p>

          <div class="flex items-center gap-3 pt-5 border-t border-surface-600/15">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-primary-500/20 to-accent-500/20 text-primary-300 font-bold text-sm border border-primary-500/20">
              {t.author.charAt(0)}
            </div>
            <div class="flex-1">
              <div class="font-semibold text-surface-200 text-sm">{t.author}</div>
              <div class="text-xs text-surface-500">{t.role}</div>
            </div>
            <span class="text-xs font-semibold text-accent-400 bg-accent-500/10 px-2.5 py-1 rounded-full border border-accent-500/15">{t.service}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
