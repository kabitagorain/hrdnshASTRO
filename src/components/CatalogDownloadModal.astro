---
// CatalogDownloadModal.astro
//
// CRITICAL DESIGN: generate.js is NOT in the initial HTML.
// It is injected dynamically ONLY when the user clicks "Download PDF Catalog".
// This prevents any auto-submit / auto-popup / flash on page load.
//
// Flow:
// 1. User clicks button → Alpine store opens modal + calls window.loadCatalogForm()
// 2. loadCatalogForm() injects generate.js → form renders
// 3. setupCatalogForm() attaches: iframe target, validation, submit handler
// 4. User fills form, clicks submit → browser validates required fields
// 5. On valid submit → data goes to Mautic via hidden iframe
// 6. After 2s → PDF downloads + success state shown → auto-closes after 5s
---

<!-- x-cloak: hidden until Alpine removes it after init — prevents ALL flash -->
<div x-cloak x-data>
  <!-- Backdrop -->
  <div
    x-show="$store.catalogModal.open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm"
    @click="$store.catalogModal.open = false"
    aria-hidden="true"
  ></div>

  <!-- Modal panel -->
  <div
    x-show="$store.catalogModal.open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95 translate-y-4"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 scale-100 translate-y-0"
    x-transition:leave-end="opacity-0 scale-95 translate-y-4"
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    @click.self="$store.catalogModal.open = false"
    @keydown.escape.window="$store.catalogModal.open = false"
    role="dialog"
    aria-modal="true"
    aria-labelledby="catalog-modal-title"
  >
    <div class="relative w-full max-w-md">
      <!-- Close button -->
      <button
        x-show="!$store.catalogModal.submitted"
        x-cloak
        @click="$store.catalogModal.open = false"
        class="absolute -top-12 right-0 text-surface-400 hover:text-surface-200 transition-colors"
        aria-label="Close modal"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- ===== SUCCESS STATE ===== -->
      <div
        x-show="$store.catalogModal.submitted"
        x-transition:enter="transition ease-out duration-400"
        x-transition:enter-start="opacity-0 scale-90"
        x-transition:enter-end="opacity-100 scale-100"
        class="relative rounded-2xl border border-surface-700/50 p-8 sm:p-10 text-center overflow-hidden"
        style="background: linear-gradient(180deg, #111827 0%, #0B1120 100%);"
      >
        <div class="absolute -inset-[1px] rounded-2xl bg-gradient-to-b from-green-500/15 via-transparent to-emerald-500/10 -z-10 blur-[1px]"></div>
        <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-green-500/50 to-transparent"></div>
        <div class="relative">
          <div class="mx-auto mb-6 inline-flex items-center justify-center">
            <div class="relative">
              <div class="w-16 h-16 rounded-full bg-green-500/10 border-2 border-green-500/30 flex items-center justify-center">
                <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="absolute inset-0 w-16 h-16 rounded-full border-2 border-green-500/20 animate-ping"></div>
            </div>
          </div>
          <h3 class="text-xl font-bold text-surface-100 mb-2">Catalog on its way!</h3>
          <p class="text-surface-400 text-sm mb-1">Your download should start automatically.</p>
          <p class="text-surface-500 text-xs mb-6">This window will close in a few seconds...</p>
          <a
            href="/Service_Product_Catalog.pdf"
            download
            class="inline-flex items-center gap-2.5 rounded-xl bg-primary-600 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-500 hover:shadow-lg hover:shadow-primary-500/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download PDF Now
          </a>
        </div>
      </div>

      <!-- ===== FORM STATE ===== -->
      <div
        x-show="!$store.catalogModal.submitted"
        class="relative rounded-2xl border border-surface-700/50 overflow-hidden"
        style="background: linear-gradient(180deg, #111827 0%, #0B1120 100%);"
      >
        <div class="absolute -inset-[1px] rounded-2xl bg-gradient-to-b from-primary-500/20 via-transparent to-accent-500/10 -z-10 blur-[1px]"></div>
        <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-primary-500/60 to-transparent"></div>

        <!-- Header -->
        <div class="relative px-6 pt-7 pb-5 border-b border-surface-700/20">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-transparent"></div>
          <div class="relative flex items-start gap-4">
            <div class="shrink-0 relative">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500/15 to-primary-600/5 border border-primary-500/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-primary-500 border-2 border-[#111827] flex items-center justify-center">
                <span class="text-[8px] font-bold text-white">PDF</span>
              </div>
            </div>
            <div class="min-w-0">
              <h3 id="catalog-modal-title" class="text-lg font-bold text-surface-100 leading-tight">Download Service Catalog</h3>
              <p class="mt-1 text-xs text-surface-500 leading-relaxed">Complete overview of all services, pricing &amp; deliverables</p>
            </div>
          </div>
        </div>

        <!-- Mautic form container — generate.js injected here ONLY when modal opens -->
        <div class="px-6 py-5" id="mautic-modal-form">
          <div id="mautic-form-loading" class="text-center py-8">
            <div class="inline-block w-6 h-6 border-2 border-primary-500/30 border-t-primary-500 rounded-full animate-spin"></div>
            <p class="mt-3 text-sm text-surface-500">Loading form...</p>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="px-6 pb-5 flex items-center justify-center gap-4 border-t border-surface-700/15 pt-4">
          <span class="flex items-center gap-1.5 text-xs text-surface-500">
            <svg class="w-3 h-3 text-surface-500/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Secure &amp; Private
          </span>
          <span class="text-surface-700">|</span>
          <span class="text-xs text-surface-500">No spam, ever</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!--
  FORM LOGIC — runs synchronously before Alpine (is:inline).

  window.loadCatalogForm() — called from resume.astro button click.
  Dynamically injects generate.js, waits for form to render, then sets up
  validation + submit handler.

  setupCatalogForm(form):
  1. ALWAYS prevents default submit (we control everything)
  2. Manual validation — checks Mautic-required fields (label with *, data-validate,
     HTML5 required). Mautic forms often DON'T use HTML5 required attributes.
  3. On valid: submits to Mautic via fetch() (no iframe, no X-Frame-Options issue)
  4. After response: PDF downloads + success state shown
-->
<script is:inline>
window.loadCatalogForm = function() {
  var container = document.getElementById('mautic-modal-form');
  if (!container || container.dataset.loaded) return;
  container.dataset.loaded = '1';

  // Inject generate.js ONLY now — not in the initial HTML
  var script = document.createElement('script');
  script.src = '//crm.healthforyou.nl/form/generate.js?id=1';
  container.appendChild(script);

  // Poll for the form to appear (generate.js is async)
  var attempts = 0;
  var waitForForm = setInterval(function() {
    attempts++;
    var form = document.querySelector('#mautic-modal-form form');
    if (!form) {
      if (attempts > 50) clearInterval(waitForForm); // 15s timeout
      return;
    }
    clearInterval(waitForForm);
    if (form.__catalogSetup) return;
    form.__catalogSetup = true;

    // Hide the loading spinner — form is ready
    var loader = document.getElementById('mautic-form-loading');
    if (loader) loader.remove();
    // Small delay so Mautic finishes its own event binding first
    setTimeout(function() { setupCatalogForm(form); }, 500);
  }, 300);
};

function setupCatalogForm(form) {
  // Block Mautic from calling form.submit() directly (bypasses our validation)
  form.submit = function() {};

  form.removeAttribute('novalidate');

  // Submit handler — capture phase runs BEFORE Mautic's handlers
  form.addEventListener('submit', function(e) {
    // ALWAYS prevent default — we submit via fetch, not browser
    e.preventDefault();
    e.stopPropagation();

    // --- Manual validation ---
    var valid = true;
    var fields = form.querySelectorAll('input:not([type=hidden]):not([type=submit]):not([type=button]), select, textarea');
    for (var i = 0; i < fields.length; i++) {
      var field = fields[i];
      var isRequired = false;

      // Check 1: HTML5 required attribute
      if (field.hasAttribute('required')) isRequired = true;

      // Check 2: Mautic data-validate attribute (e.g. "email,required")
      if (!isRequired) {
        var dv = field.getAttribute('data-validate') || '';
        if (dv.indexOf('required') !== -1) isRequired = true;
      }

      // Check 3: Mautic label ends with * (required indicator)
      if (!isRequired) {
        var label = null;
        if (field.id) label = form.querySelector('label[for="' + field.id + '"]');
        if (!label) {
          var row = field.closest('.mauticform-field-row') || field.parentElement;
          if (row) label = row.querySelector('.mauticform-label');
        }
        if (label && label.textContent && label.textContent.indexOf('*') !== -1) {
          isRequired = true;
        }
      }

      // Check 4: Mautic error message element exists (Mautic adds these for required fields)
      if (!isRequired) {
        var errEl = field.parentElement.querySelector('.mauticform-errormsg');
        if (errEl) isRequired = true;
      }

      if (isRequired) {
        if (!field.value || field.value.trim() === '') {
          valid = false;
          field.classList.add('mauticform-notvalid');
          var msg = field.parentElement.querySelector('.mauticform-errormsg');
          if (msg) msg.style.display = '';
        } else {
          field.classList.remove('mauticform-notvalid');
          var msg2 = field.parentElement.querySelector('.mauticform-errormsg');
          if (msg2) msg2.style.display = 'none';
        }
      }
    }

    if (!valid) return; // Don't submit, don't download

    // --- Valid: submit to Mautic via fetch (no iframe, no X-Frame-Options issues) ---
    var action = form.getAttribute('action') || window.location.href;
    var formData = new FormData(form);

    fetch(action, {
      method: 'POST',
      body: formData,
      mode: 'no-cors' // Mautic is cross-origin, we don't need to read the response
    }).catch(function() {
      // Even if fetch fails (network), data was likely sent — continue gracefully
    });

    // Download PDF + show success immediately after sending
    setTimeout(function() {
      var store = window.Alpine ? Alpine.store('catalogModal') : null;
      if (!store || !store.open) return;

      var a = document.createElement('a');
      a.href = '/Service_Product_Catalog.pdf';
      a.download = 'Service_Product_Catalog.pdf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);

      store.submitted = true;
      setTimeout(function() {
        store.submitted = false;
        store.open = false;
      }, 5000);
    }, 1000);
  }, true);
}
</script>
