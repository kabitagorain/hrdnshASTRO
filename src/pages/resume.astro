---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Contact from '@components/Contact.astro';
import { profile, services, seoData } from '@data/services';
---

<Layout title={seoData.resume.title} description={seoData.resume.description} schemaType="person">
  <Header />

  <!-- Page Hero -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-20 overflow-hidden dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-600/8 rounded-full blur-[120px]"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <a href="/" class="inline-flex items-center gap-2 text-sm text-surface-500 hover:text-surface-300 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Home
      </a>

      <div class="flex flex-col md:flex-row items-center gap-8">
        <!-- Avatar -->
        <div class="avatar-ring shrink-0">
          
            <img src="/avatar.png" alt={profile.name} class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover" width="144" height="144" fetchpriority="high" />
       
        </div>

        <div class="text-center md:text-left">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
            <span class="text-surface-100">{profile.name}</span>
          </h1>
          <p class="mt-3 text-xl text-primary-400 font-medium">{profile.title}</p>
          <p class="mt-4 text-surface-400 max-w-xl">{profile.tagline}</p>

          <!-- Quick info -->
          <div class="mt-6 flex flex-wrap justify-center md:justify-start gap-3">
            <span class="inline-flex items-center gap-1.5 text-sm text-surface-400">
              <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              {profile.location}
            </span>
            <span class="inline-flex items-center gap-1.5 text-sm text-surface-400">
              <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {profile.email}
            </span>
            <span class="inline-flex items-center gap-1.5 text-sm text-surface-400">
              <svg class="w-4 h-4 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {profile.stats[3].value} response time
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main>
    <!-- Download CTA -->
    <section class="relative py-16 sm:py-20" style="background: linear-gradient(180deg, #0c1220 0%, #111827 100%);">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="animate-on-scroll glass-card rounded-2xl p-8 sm:p-12 text-center relative overflow-hidden">
          <!-- Decorative gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"></div>

          <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-500/10 border border-primary-500/15 mb-6">
              <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>

            <h2 class="text-2xl sm:text-3xl font-black text-surface-100 mb-4">
              Download My Service Catalog
            </h2>
            <p class="text-surface-400 max-w-2xl mx-auto mb-8 text-base leading-relaxed">
              Get the complete overview of all {services.length} services with detailed descriptions, deliverables, pricing, and proven outcomes. Perfect for sharing with your team or stakeholders.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href="/Service_Product_Catalog.pdf"
                download
                class="btn-glow inline-flex items-center gap-2.5 rounded-xl bg-primary-600 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-primary-500 hover:-translate-y-0.5"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download PDF Catalog
              </a>
              <a
                href="#services-list"
                class="inline-flex items-center gap-2 rounded-xl border border-surface-600/30 px-8 py-4 text-base font-semibold text-surface-300 transition-all hover:border-primary-500/30 hover:text-primary-400"
              >
                View Services Below
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Summary -->
    <section id="services-list" class="relative py-16 sm:py-20 dark-section noise-overlay">
      <div class="absolute inset-0 dot-pattern"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-surface-100 text-center mb-12 animate-on-scroll">
          All <span class="gradient-text">Services</span> at a Glance
        </h2>

        <div class="space-y-4">
          {services.map((service) => (
            <a
              href={`/services/${service.id}`}
              class="animate-on-scroll glass-card glass-card-hover rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 group"
            >
              <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-xl border border-primary-500/10 shrink-0">
                {service.icon}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1">
                  <h3 class="text-lg font-bold text-surface-100 group-hover:text-primary-300 transition-colors">{service.title}</h3>
                  <span class="text-xs text-surface-500 font-mono">{service.timeline}</span>
                </div>
                <p class="text-sm text-surface-400 line-clamp-2">{service.businessOwner.summary}</p>
              </div>
              <div class="flex items-center gap-4 shrink-0">
                <div class="text-right">
                  <div class="text-xl font-black text-surface-100">${service.pricing.oneTime}</div>
                  <div class="text-xs text-surface-500">or ${service.pricing.weekly}/wk</div>
                </div>
                <svg class="w-5 h-5 text-surface-600 group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="relative py-16 sm:py-20" style="background: linear-gradient(180deg, #0c1220 0%, #111827 100%);">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-black text-surface-100 text-center mb-12 animate-on-scroll">
          Technical <span class="gradient-text">Expertise</span>
        </h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {profile.techStack.map((cat) => (
            <div class="animate-on-scroll glass-card rounded-2xl p-6">
              <h3 class="text-sm font-bold text-accent-400 uppercase tracking-wider mb-4">{cat.category}</h3>
              <div class="flex flex-wrap gap-2">
                {cat.items.map((item) => (
                  <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-surface-600/15 text-sm text-surface-300 font-mono">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Contact />
  <Footer />
</Layout>
