---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { profile, siteData, seoData } from '@data/services';

const effectiveDate = 'April 5, 2026';
const siteName = siteData.url.replace('https://', '');
---

<Layout title={seoData.privacy.title} description={seoData.privacy.description} schemaType="legal" noindex={true}>
  <Header />

  <!-- Page Hero -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-20 overflow-hidden dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>
    <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-primary-600/8 rounded-full blur-[120px]"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-surface-500 hover:text-surface-300 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Home
      </a>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <span class="text-sm font-semibold text-accent-400">Your Privacy Matters</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
          <span class="text-surface-100">Privacy</span>
          <span class="gradient-text"> Policy</span>
        </h1>

        <p class="mt-6 text-lg text-surface-400 leading-relaxed">
          This policy explains how we collect, use, and protect your data when you visit {siteName}. We believe in transparency — here's exactly what happens with your information.
        </p>

        <div class="mt-6 flex items-center gap-3 text-sm text-surface-500">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span>Effective: {effectiveDate}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <main class="relative dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">

      <!-- Overview -->
      <section class="mb-16 animate-on-scroll">
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100 mb-4">Overview</h2>
          <p class="text-surface-400 leading-relaxed mb-4">
            {siteName} ("we," "us," or "our") is the personal portfolio and service website of {profile.name}. We are committed to protecting your privacy and being transparent about the data we collect. This Privacy Policy describes how we handle information when you visit our website.
          </p>
          <p class="text-surface-400 leading-relaxed">
            We use industry-standard tools to understand how visitors interact with our site so we can improve the experience. Specifically, we use <span class="text-surface-200 font-medium">Cloudflare Zaraz</span> as a privacy-first proxy to manage third-party services, and <span class="text-surface-200 font-medium">Google Analytics</span> (routed through Cloudflare Zaraz) for website analytics. You are in full control of your data through the consent banner displayed on your first visit.
          </p>
        </div>
      </section>

      <!-- 1. Information We Collect -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-600/20 text-primary-400 text-sm font-bold">1</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Information We Collect</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <h3 class="text-lg font-semibold text-surface-200 mb-3">Automatically Collected Data</h3>
          <p class="text-surface-400 leading-relaxed mb-6">
            When you visit {siteName}, certain information is collected automatically through Cloudflare Zaraz and Google Analytics. This data is processed on our behalf and helps us understand how visitors use our website. We do not collect this data directly — it is gathered by the tools described below. The specific data points include:
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-6">
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">Device Information</div>
                <div class="text-xs text-surface-500 mt-0.5">Browser type, operating system, screen resolution, device type</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">Approximate Location</div>
                <div class="text-xs text-surface-500 mt-0.5">Country and city-level (not precise GPS coordinates)</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">Usage Data</div>
                <div class="text-xs text-surface-500 mt-0.5">Pages visited, time spent, referrer source, click patterns</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">Anonymized Identifier</div>
                <div class="text-xs text-surface-500 mt-0.5">Randomized client ID (no personal identity linked)</div>
              </div>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-surface-200 mb-3">Data You Provide Voluntarily</h3>
          <p class="text-surface-400 leading-relaxed">
            If you choose to contact us through the contact form, email, WhatsApp, or Upwork links provided on this website, you may share personal information such as your name, email address, phone number, and project details. This information is used solely to respond to your inquiry and is not collected or stored by our website itself — it is transmitted directly to the respective communication channel (email client, WhatsApp, or Upwork).
          </p>
        </div>
      </section>

      <!-- 2. Cloudflare Zaraz -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent-600/20 text-accent-400 text-sm font-bold">2</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Cloudflare Zaraz — Our Privacy-First Tool Manager</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-surface-400 leading-relaxed mb-4">
            We use <span class="text-surface-200 font-medium">Cloudflare Zaraz</span> as our centralized tool management and consent platform. Cloudflare Zaraz is a privacy-focused service by Cloudflare, Inc. that acts as a proxy between your browser and third-party services like Google Analytics. This architecture provides several important privacy benefits over traditional tag managers:
          </p>
          <div class="space-y-3 mb-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <p class="text-surface-400 leading-relaxed">
                <span class="text-surface-200 font-medium">Server-Side Processing:</span> Third-party scripts run on Cloudflare's servers rather than directly in your browser. This means fewer third-party cookies and trackers are loaded on your device, reducing your exposure to cross-site tracking.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <p class="text-surface-400 leading-relaxed">
                <span class="text-surface-200 font-medium">Improved Page Performance:</span> By offloading third-party scripts to Cloudflare's edge network, our website loads faster and uses fewer of your device's resources. You get a smoother browsing experience.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <p class="text-surface-400 leading-relaxed">
                <span class="text-surface-200 font-medium">Consent Management:</span> Cloudflare Zaraz powers the consent banner you see when you first visit our site. It remembers your preferences and only activates analytics tools if you explicitly consent. Your choice is respected across sessions.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <p class="text-surface-400 leading-relaxed">
                <span class="text-surface-200 font-medium">Data Minimization:</span> Cloudflare Zaraz strips unnecessary parameters and personally identifiable information (PII) before forwarding data to analytics services. Only the essential, anonymized data points are passed through.
              </p>
            </div>
          </div>
          <div class="p-4 rounded-lg bg-surface-800/50 border border-surface-700/30">
            <p class="text-xs text-surface-500 leading-relaxed">
              <span class="text-surface-400 font-semibold">Cloudflare's Privacy Policy:</span> For complete details on how Cloudflare processes data, please refer to <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300 underline underline-offset-2 transition-colors">Cloudflare's Privacy Policy</a>. Cloudflare is committed to data protection and is compliant with GDPR, CCPA, and other major privacy regulations.
            </p>
          </div>
        </div>
      </section>

      <!-- 3. Google Analytics (via Zaraz) -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-600/20 text-primary-400 text-sm font-bold">3</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Google Analytics — Proxied Through Cloudflare Zaraz</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-surface-400 leading-relaxed mb-4">
            We use <span class="text-surface-200 font-medium">Google Analytics</span> to understand how visitors interact with our website — which pages are popular, how long people stay, and where they come from. This helps us improve the content and user experience of our site. Importantly, Google Analytics on our site is <span class="text-surface-200 font-medium">not loaded directly in your browser</span>. Instead, it is routed through Cloudflare Zaraz's server-side proxy.
          </p>

          <h3 class="text-lg font-semibold text-surface-200 mb-3">What This Means for You</h3>
          <p class="text-surface-400 leading-relaxed mb-4">
            Because Google Analytics runs through Cloudflare Zaraz, the traditional Google Analytics JavaScript library (gtag.js / ga.js) is <span class="text-surface-200 font-medium">not executed in your browser</span>. This means Google's cookies are not set directly on your device by Google's scripts. Instead, Cloudflare Zaraz collects the necessary data server-side and forwards an anonymized subset to Google Analytics on our behalf. This significantly reduces the data Google receives compared to a standard Google Analytics implementation.
          </p>

          <h3 class="text-lg font-semibold text-surface-200 mb-3">Data Retention & Anonymization</h3>
          <p class="text-surface-400 leading-relaxed mb-4">
            We have configured Google Analytics with the following privacy-focused settings:
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-6">
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">IP Anonymization</div>
                <div class="text-xs text-surface-500 mt-0.5">Visitor IP addresses are anonymized before any data processing</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">Data Retention</div>
                <div class="text-xs text-surface-500 mt-0.5">User and event data is automatically deleted after 14 months</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">No Advertising Features</div>
                <div class="text-xs text-surface-500 mt-0.5">Google Ads remarketing and advertising features are disabled</div>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-800/30">
              <svg class="w-5 h-5 text-success-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <div class="text-sm font-medium text-surface-200">No Data Sharing</div>
                <div class="text-xs text-surface-500 mt-0.5">Google Analytics data is not shared with any third parties</div>
              </div>
            </div>
          </div>

          <div class="p-4 rounded-lg bg-surface-800/50 border border-surface-700/30">
            <p class="text-xs text-surface-500 leading-relaxed">
              <span class="text-surface-400 font-semibold">Google's Privacy Policy:</span> Google processes data received through Google Analytics according to its own privacy policy. For more information, visit <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300 underline underline-offset-2 transition-colors">Google's Privacy Policy</a>. You can also opt out of Google Analytics tracking by installing the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300 underline underline-offset-2 transition-colors">Google Analytics Opt-out Browser Add-on</a>.
            </p>
          </div>
        </div>
      </section>

      <!-- 4. Consent Banner -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent-600/20 text-accent-400 text-sm font-bold">4</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Consent Banner & Your Choices</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-surface-400 leading-relaxed mb-4">
            When you visit {siteName} for the first time, a consent banner powered by <span class="text-surface-200 font-medium">Cloudflare Zaraz</span> appears at the bottom of your screen. This banner gives you full control over whether analytics tools are activated. Here's how it works:
          </p>
          <div class="space-y-4 mb-6">
            <div class="flex items-start gap-4">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-primary-600/15 text-primary-400 text-sm font-bold shrink-0">1</div>
              <div>
                <div class="text-sm font-semibold text-surface-200 mb-1">You See the Banner</div>
                <p class="text-sm text-surface-400 leading-relaxed">On your first visit, the consent banner asks if you agree to analytics data collection. No tracking occurs until you make a choice.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-primary-600/15 text-primary-400 text-sm font-bold shrink-0">2</div>
              <div>
                <div class="text-sm font-semibold text-surface-200 mb-1">You Decide</div>
                <p class="text-sm text-surface-400 leading-relaxed">If you accept, Cloudflare Zaraz will begin proxying anonymized analytics data to Google Analytics. If you decline, no analytics tools are activated and no usage data is sent to any third party.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-primary-600/15 text-primary-400 text-sm font-bold shrink-0">3</div>
              <div>
                <div class="text-sm font-semibold text-surface-200 mb-1">Your Choice Is Saved</div>
                <p class="text-sm text-surface-400 leading-relaxed">Your preference is stored in your browser's local storage. You won't be asked again on subsequent visits unless you clear your browser data. You can change your decision at any time by clearing the stored consent.</p>
              </div>
            </div>
          </div>
          <div class="p-4 rounded-lg bg-accent-500/5 border border-accent-500/15">
            <p class="text-sm text-surface-400 leading-relaxed">
              <span class="text-accent-400 font-semibold">Important:</span> If you decline analytics consent, Cloudflare Zaraz will not load Google Analytics or any other third-party analytics tools. Your browsing experience on our site remains fully functional — the only difference is that we won't receive any usage analytics data from your visit.
            </p>
          </div>
        </div>
      </section>

      <!-- 5. Cookies -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-600/20 text-primary-400 text-sm font-bold">5</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Cookies & Local Storage</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-surface-400 leading-relaxed mb-4">
            Our website uses minimal cookie and local storage technology. Because Google Analytics is proxied through Cloudflare Zaraz (server-side), we do not set Google Analytics cookies directly in your browser. The following technical storage mechanisms are used:
          </p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-surface-700/30">
                  <th class="text-left py-3 pr-4 text-surface-300 font-semibold">Storage Type</th>
                  <th class="text-left py-3 pr-4 text-surface-300 font-semibold">Purpose</th>
                  <th class="text-left py-3 pr-4 text-surface-300 font-semibold">Duration</th>
                  <th class="text-left py-3 text-surface-300 font-semibold">Can Be Disabled</th>
                </tr>
              </thead>
              <tbody class="text-surface-400">
                <tr class="border-b border-surface-700/15">
                  <td class="py-3 pr-4 font-mono text-xs text-primary-400">Zaraz Consent</td>
                  <td class="py-3 pr-4">Remembers your consent choice (accept/decline)</td>
                  <td class="py-3 pr-4">Until cleared</td>
                  <td class="py-3"><span class="text-success-400 font-medium">Yes</span></td>
                </tr>
                <tr class="border-b border-surface-700/15">
                  <td class="py-3 pr-4 font-mono text-xs text-primary-400">Cloudflare __cf_bm</td>
                  <td class="py-3 pr-4">Cloudflare Bot Management (security, not analytics)</td>
                  <td class="py-3 pr-4">30 minutes</td>
                  <td class="py-3"><span class="text-warning-400 font-medium">Not recommended</span></td>
                </tr>
                <tr>
                  <td class="py-3 pr-4 font-mono text-xs text-primary-400">Theme Preference</td>
                  <td class="py-3 pr-4">Remembers your light/dark theme selection</td>
                  <td class="py-3 pr-4">Until cleared</td>
                  <td class="py-3"><span class="text-success-400 font-medium">Yes</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-surface-500 text-xs mt-4 leading-relaxed">
            Note: Cloudflare security cookies (like __cf_bm) are set by Cloudflare's infrastructure for bot protection and DDoS mitigation. These are essential for keeping the website secure and are not related to analytics or tracking. They cannot be disabled without also disabling Cloudflare's security protection.
          </p>
        </div>
      </section>

      <!-- 6. Third-Party Services -->
      <section class="mb-16 animate-on-scroll">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent-600/20 text-accent-400 text-sm font-bold">6</span>
          <h2 class="text-xl sm:text-2xl font-bold text-surface-100">Third-Party Services & Links</h2>
        </div>
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-surface-400 leading-relaxed mb-4">
