---
// Pre-render services hub for better SEO indexing
export const prerender = true;

import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Contact from '@components/Contact.astro';
import { services, profile, siteData } from '@data/services';

// Group services by category for better structure
const serviceCategories = [
  {
    name: 'AI & Automation',
    icon: '🤖',
    description: 'Intelligent systems that automate workflows, enhance decision-making, and deliver 24/7 operational efficiency using cutting-edge AI and autonomous agent technologies.',
    ids: [
      'agentic-ai-rag-orchestration',
      'openclaw-enterprise-web-gateway',
      'private-ai-agent-vps',
    ],
  },
  {
    name: 'Backend & Infrastructure',
    icon: '⚡',
    description: 'High-performance server architecture, database optimization, and scalable infrastructure engineering designed to handle enterprise-level traffic with sub-50ms response times.',
    ids: [
      'high-concurrency-backend-optimization',
      'devops-security-hardening',
    ],
  },
  {
    name: 'Full-Stack Web Development',
    icon: '🚀',
    description: 'Modern, SEO-dominant web applications built with Island Architecture for instant load times, maximum conversion rates, and long-term maintainability.',
    ids: [
      'fullstack-modern-web-architecture',
      'personal-portfolio-high-conversion',
    ],
  },
  {
    name: 'Enterprise & ERP',
    icon: '🏭',
    description: 'Custom manufacturing ERP systems, shop floor intelligence, and open-source business OS implementations for operational transparency and data sovereignty.',
    ids: [
      'industrial-automation-erp',
      'erpnext-crm-deployment',
      'manufacturing-automation-erp',
    ],
  },
  {
    name: 'Financial & Trading Systems',
    icon: '📈',
    description: 'Institutional-grade algorithmic trading engines and quantitative analysis systems for Forex, Crypto, and multi-platform automated execution.',
    ids: [
      'algorithmic-trading-fintech',
    ],
  },
  {
    name: 'E-Commerce',
    icon: '🛡️',
    description: 'Conversion engineering, performance hardening, and revenue protection for WooCommerce, Shopify, and OpenCart stores — from checkout optimization to edge security.',
    ids: [
      'ecommerce-reliability-maintenance',
      'ecommerce-performance-hardening',
    ],
  },
  {
    name: 'Clinical AI',
    icon: '⚕️',
    description: 'Secure, locally-hosted AI assistant systems designed for clinical settings to ensure patient data privacy and high-accuracy research retrieval.',
    ids: [
      'doctor-rag-clinical-assistant',
      'legal-specialized-rag-infrastructure',
    ],
  },
];

function getServicesByIds(ids: string[]) {
  return ids.map((id) => services.find((s) => s.id === id)).filter(Boolean);
}

// BreadcrumbList JSON-LD for services index
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteData.url,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: new URL('/services', Astro.site).href,
    },
  ],
};

// ItemList JSON-LD for all services
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Professional Services by Haradhan Sharma',
  description: siteData.defaultDescription,
  numberOfItems: services.length,
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: new URL(`/services/${s.id}`, Astro.site).href,
  })),
};
---

<Layout
  title={`All Services — ${profile.fname} ${profile.lname} | AI, Web, DevOps & Enterprise Solutions`}
  description={`${services.length} professional services covering AI agents, full-stack development, DevOps, ERP systems, e-commerce optimization, and algorithmic trading. Expert engineering with transparent pricing and measurable outcomes.`}
  schemaType="service"
  ogType="business.business"
  customJsonLd={[breadcrumbJsonLd, itemListJsonLd]}
>
  <Header />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-20 overflow-hidden dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-600/8 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-600/6 rounded-full blur-[100px]"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-surface-500">
          <li><a href="/" class="hover:text-surface-300 transition-colors">Home</a></li>
          <li><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
          <li class="text-surface-300 font-medium">Services</li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-2 mb-6 badge-glow">
          <span class="text-sm font-semibold text-accent-400">{services.length} Professional Services</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
          <span class="text-surface-100">Expert Engineering</span><br />
          <span class="gradient-text">for Every Business Need</span>
        </h1>

        <p class="mt-6 text-lg text-surface-400 leading-relaxed">
          From AI-powered autonomous agents to industrial ERP systems — each service is designed to deliver measurable, production-grade results. Transparent pricing, clear deliverables, and ongoing support.
        </p>

        <!-- Quick stats -->
        <div class="mt-8 flex flex-wrap gap-4">
          <div class="flex items-center gap-2 text-sm text-surface-400">
            <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>No recurring license fees</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-surface-400">
            <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Production-ready deliverables</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-surface-400">
            <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Post-launch support included</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main id="main-content">
    {serviceCategories.map((category, ci) => {
      const categoryServices = getServicesByIds(category.ids);
      return (
        <section
          class:list={[
            'relative py-16 sm:py-20',
            ci % 2 === 0 ? 'dark-section noise-overlay' : '',
          ]}
          style={ci % 2 !== 0 ? 'background: linear-gradient(180deg, #0c1220 0%, #111827 50%, #0c1220 100%);' : ''}
        >
          <div class:list={['absolute inset-0', ci % 2 === 0 ? 'dot-pattern' : '']}></div>

          <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <!-- Category Header -->
            <div class="flex items-center gap-3 mb-4 animate-on-scroll">
              <span class="text-3xl">{category.icon}</span>
              <h2 class="text-2xl sm:text-3xl font-black text-surface-100">{category.name}</h2>
              <div class="flex-1 section-divider ml-4"></div>
            </div>
            <p class="text-surface-400 max-w-3xl mb-12 leading-relaxed animate-on-scroll">
              {category.description}
            </p>

            <!-- Service Cards -->
            <div class:list={[
              'grid gap-6',
              categoryServices.length === 1 ? 'max-w-2xl' : categoryServices.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-3',
            ]}>
              {categoryServices.map((service) => (
                <a
                  href={`/services/${service!.id}`}
                  class="animate-on-scroll group glass-card glass-card-hover rounded-2xl p-6 sm:p-8 relative overflow-hidden"
                >
                  <!-- Hover shimmer -->
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                    <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"></div>
                  </div>

                  <div class="relative z-10">
                    <!-- Top row -->
                    <div class="flex items-start justify-between mb-6">
                      <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500/20 to-accent-500/20 text-2xl border border-primary-500/10 transition-transform group-hover:scale-110" role="img" aria-label={service!.title}>
                        {service!.icon}
                      </div>
                      <span class="text-xs font-bold text-surface-600 tracking-widest font-mono">{service!.number}</span>
                    </div>

                    <!-- Title -->
                    <h3 class="text-xl font-bold text-surface-100 mb-3 group-hover:text-primary-300 transition-colors">
                      {service!.title}
                    </h3>

                    <!-- Tagline -->
                    <p class="text-surface-400 text-sm leading-relaxed mb-6">
                      {service!.tagline}
                    </p>

                    <!-- Business preview -->
                    <div class="p-4 rounded-xl bg-white/[0.03] border border-surface-600/10 mb-6">
                      <p class="text-xs font-semibold text-accent-400 uppercase tracking-wider mb-2">For Business Owners</p>
                      <p class="text-sm text-surface-300 leading-relaxed line-clamp-3">
                        {service!.businessOwner.summary}
                      </p>
                    </div>

                    <!-- Tech Stack Preview -->
                    <div class="flex flex-wrap gap-1.5 mb-6">
                      {service!.techStack.slice(0, 4).map((tech) => (
                        <span class="px-2 py-0.5 rounded-md bg-white/5 border border-surface-600/10 text-xs text-surface-500 font-mono">
                          {tech}
                        </span>
                      ))}
                      {service!.techStack.length > 4 && (
                        <span class="px-2 py-0.5 rounded-md bg-white/5 border border-surface-600/10 text-xs text-surface-500 font-mono">
                          +{service!.techStack.length - 4}
                        </span>
                      )}
                    </div>

                    <!-- Bottom row: Price + Arrow -->
                    <div class="flex items-center justify-between pt-4 border-t border-surface-600/15">
                      <div>
                        <span class="text-xs text-surface-500">Starting from</span>
                        <div class="text-xl font-black text-surface-100">${service!.pricing.oneTime}</div>
                      </div>
                      <div class="flex items-center gap-1.5 text-sm font-semibold text-primary-400 group-hover:gap-2.5 transition-all">
                        Explore {service!.title.split(' ').slice(0, 2).join(' ')}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      );
    })}

    <!-- CTA -->
    <section class="relative py-16 sm:py-20" style="background: #070b14;">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="glass-card rounded-2xl p-8 sm:p-12 text-center relative overflow-hidden animate-on-scroll">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"></div>
          <div class="relative z-10">
            <h2 class="text-2xl sm:text-3xl font-black text-surface-100 mb-4">
              Not sure which service fits your needs?
            </h2>
            <p class="text-surface-400 max-w-2xl mx-auto mb-8 leading-relaxed">
              Let's discuss your project requirements and find the right solution. Every project starts with a free consultation — no commitments, no pressure.
            </p>
            <a
              href="/#contact"
              class="btn-glow inline-flex items-center gap-2 rounded-xl bg-primary-600 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-primary-500 hover:-translate-y-0.5"
            >
              Let's Talk
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Contact />
  <Footer />
</Layout>
