---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteData } from '../data/services';
---

<Layout title="404 — Page Not Found" description="The page you're looking for doesn't exist." schemaType="none">
  <Header />

  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/5 rounded-full blur-[150px]"></div>

    <div class="relative text-center px-4 sm:px-6">
      <div class="mb-8">
        <span class="text-[120px] sm:text-[180px] font-black leading-none gradient-text select-none">404</span>
      </div>

      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black text-surface-100 tracking-tight mb-4">
        Page not found
      </h1>

      <p class="text-surface-400 text-lg max-w-lg mx-auto mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Don't worry — let's get you back on track.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="btn-glow inline-flex items-center gap-2 rounded-xl bg-primary-600 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-primary-500 hover:-translate-y-0.5"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to Home
        </a>
        <a
          href="/#services"
          class="inline-flex items-center gap-2 rounded-xl border border-surface-600/30 px-8 py-4 text-base font-semibold text-surface-300 transition-all hover:border-primary-500/30 hover:text-primary-400"
        >
          View Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

