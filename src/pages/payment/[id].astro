---
/**
 * payment/[id].astro — Manual Payment Gateway Page (SSR)
 *
 * Flow:
 *   1. Visitor arrives via /payment/{serviceId}?type=onetime|weekly
 *      (routed here when "Manual Invoice" is selected in TosConsent dropdown)
 *   2. Step 1 — Order summary + manual payment instructions
 *   3. Step 2 — Submit name, email, transaction ID via Web3Forms
 *   4. Step 3 — Success confirmation with reference number
 *
 * SETUP REQUIRED (2 things):
 *
 *   1. Web3Forms — sign up free at https://web3forms.com
 *      - Get your access_key from the dashboard
 *      - Replace YOUR_WEB3FORMS_KEY below
 *      - Emails will be sent to the address you registered with
 *
 *   2. Payment methods — edit the manualPaymentMethods array below
 *      with your real bank account details, bKash number, crypto wallet, etc.
 */
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { services, profile, siteData } from '@data/services';

// ╔═══════════════════════════════════════════════════════════════╗
// ║  CONFIG — Edit these with your real payment details         ║
// ╚═══════════════════════════════════════════════════════════════╝

const WEB3FORMS_KEY = '54267ba9-82f5-440c-be69-7414e32a4380';

// ── SSR: Resolve service from URL param (no getStaticPaths needed) ──
const { id } = Astro.params;
const service = services.find((s) => s.id === id);

if (!service) {
  return Astro.redirect('/404');
}

const serviceUrl = new URL(`/payment/${service.id}`, Astro.site).href;

// ── SSR: Read ?type= from real request URL (no client-side workaround) ──
const paymentType = (Astro.url.searchParams.get('type') || '').toLowerCase() === 'weekly' ? 'weekly' : 'onetime';
const price = paymentType === 'weekly' ? service.pricing.weekly : service.pricing.oneTime;
const priceLabel = paymentType === 'weekly' ? '/week' : 'one-time';
const paymentTypeDisplay = paymentType === 'weekly' ? 'Weekly Subscription' : 'One-Time Payment';

// Payment methods — defined AFTER service is resolved
const manualPaymentMethods = [
  {
    code: 'bank',
    name: 'Bank / Wire Transfer',
    icon: '🏦',
    region: 'International',
    regionColor: 'primary',
    details: [
      { label: 'Bank Name', value: 'Clear Bank(Based in GB)' },
      { label: 'Account Name', value: 'Haradhan Sharma' },
      { label: 'IBAN', value: 'GB96CLRB04281204027608' },
      { label: 'SWIFT / BIC', value: 'CLRBGB22XXX' },
      { label: 'Bank address', value: '133 Houndsditch, LONDON, EC3A 7BX' },
    ],
    note: 'For international wire transfers, please include the service name in the reference field.',
  },
  {
    code: 'bkash',
    name: 'bKash',
    icon: '📱',
    region: 'Bangladesh',
    regionColor: 'success',
    details: [
      { label: 'Account Type', value: 'Personal' },
      { label: 'bKash Number', value: '011712270815' },
      { label: 'Reference', value: `Use ID: ${service.id}` },
    ],
    note: 'Send payment via bKash "Send Money" to the number above. Keep your TrxID for verification.',
  },
  {
    code: 'crypto',
    name: 'USDT (TRC20)',
    icon: '🔗',
    region: 'Worldwide',
    regionColor: 'warning',
    details: [
      { label: 'Network', value: 'TRC20 (Tron)' },
      { label: 'Wallet Address', value: 'TNKkGiFrZ1LNpvx74CVeA6BBoFkekgQoBS' },
      { label: 'Min. Amount', value: '$10 USDT' },
    ],
    note: 'Only send USDT on TRC20 network. Do NOT send on ERC20 or other networks — funds will be lost.',
  },
];

// Serialize methods for Alpine.js
const methodsJson = JSON.stringify(manualPaymentMethods);

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteData.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: siteData.url + '/#services' },
    { '@type': 'ListItem', position: 3, name: service.title, item: new URL(`/services/${service.id}`, Astro.site).href },
    { '@type': 'ListItem', position: 4, name: 'Manual Payment', item: serviceUrl },
  ],
};
---

<Layout
  title={`Manual Payment — ${service.title} — ${profile.name}`}
  description={`Complete your manual payment for ${service.title} (${priceLabel}). Follow the payment instructions and submit your transaction ID for verification.`}
  schemaType="none"
  customJsonLd={[breadcrumbJsonLd]}
>
  <Header />

  <!-- Inject data for Alpine.js — price/type resolved SERVER-SIDE, no client-side workaround -->
  <script is:inline set:html={`
    window.__manualPayment = {
      serviceId: '${service.id}',
      serviceTitle: '${service.title.replace(/'/g, "\\'")}',
      paymentType: '${paymentType}',
      price: ${price},
      priceLabel: '${priceLabel}',
      paymentTypeDisplay: '${paymentTypeDisplay}',
      contactEmail: '${siteData.email}',
      web3formsKey: '${WEB3FORMS_KEY}',
      methods: ${methodsJson},
    };
  `}></script>

  <!-- Hero -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-20 overflow-hidden dark-section noise-overlay">
    <div class="absolute inset-0 dot-pattern"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary-600/8 rounded-full blur-[120px]"></div>

    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-surface-500 mb-8 flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-surface-300 transition-colors">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <a href="/#services" class="hover:text-surface-300 transition-colors">Services</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <a href={`/services/${service.id}`} class="hover:text-surface-300 transition-colors">{service.title}</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span class="text-surface-300">Manual Payment</span>
      </nav>

      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-3xl border border-primary-500/10 mb-5">
          {service.icon}
        </div>
        <div class="inline-flex items-center gap-2 rounded-full bg-warning-500/10 border border-warning-500/15 px-3 py-1 mb-4">
          <svg class="w-3.5 h-3.5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <span class="text-xs font-bold text-warning-400 tracking-wider uppercase">Manual Payment</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-black text-surface-100 tracking-tight">
          Complete Your Payment
        </h1>
        <p class="mt-3 text-surface-400 max-w-xl mx-auto">
          You're paying for <span class="text-surface-200 font-medium">{service.title}</span>
          — <span class="text-primary-400 font-bold">${'$'}{price} {priceLabel}</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Payment Flow -->
  <main class="pb-24" style="background: linear-gradient(180deg, #0c1220 0%, #111827 50%, #0c1220 100%);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8"
      x-data="{
        step: 'instructions',
        form: { name: '', email: '', trxId: '', method: 'bank', note: '' },
        submitting: false,
        reference: '',

        get d() { return window.__manualPayment || {}; },
        get methods() { return this.d.methods || []; },

        selectedMethodName() {
          const m = this.methods.find(m => m.code === this.form.method);
          return m ? m.icon + ' ' + m.name : 'Bank Transfer';
        },

        goToConfirm() {
          this.step = 'confirm';
          window.scrollTo({ top: 0, behavior: 'smooth' });
          this.$nextTick(() => {
            setTimeout(() => {
              document.getElementById('pay-name')?.focus();
            }, 400);
          });
        },

        goToInstructions() {
          this.step = 'instructions';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        async submitTrx() {
          if (!this.form.name || !this.form.email || !this.form.trxId) return;
          this.submitting = true;

          this.reference = 'PAY-' + this.d.serviceId.slice(0, 6).toUpperCase() + '-' + Date.now().toString(36).toUpperCase();

          try {
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({
                access_key: this.d.web3formsKey,
                subject: 'Manual Payment Confirmation - ' + this.d.serviceTitle,
                from_name: this.form.name,
                replyto: this.form.email,
                botcheck: '',
                'Reference Number': this.reference,
                'Service': this.d.serviceTitle,
                'Service ID': this.d.serviceId,
                'Payment Type': this.d.priceLabel,
                'Amount': '$' + this.d.price,
                'Payment Method': this.selectedMethodName(),
                'Payer Name': this.form.name,
                'Payer Email': this.form.email,
                'Transaction ID': this.form.trxId,
                'Additional Note': this.form.note || '-',
              }),
            });

            if (res.ok) {
              this.step = 'success';
              window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              alert('Something went wrong. Please send your transaction details to ' + this.d.contactEmail + ' directly.');
            }
          } catch (e) {
            alert('Network error. Please check your connection and try again, or email your payment details to ' + this.d.contactEmail + '.');
          } finally {
            this.submitting = false;
          }
        },
      }"
    >

      <!-- ==========================================
           STEP 1: PAYMENT INSTRUCTIONS
           ========================================== -->
      <div x-show="step === 'instructions'" x-cloak>
        <div class="glass-card rounded-2xl overflow-hidden">
          <div class="h-0.5 bg-gradient-to-r from-primary-500 via-accent-500 to-primary-500"></div>
          <div class="p-8 sm:p-10">

            <!-- Progress -->
            <div class="flex items-center gap-3 mb-8">
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white text-sm font-bold">1</div>
              <div class="flex-1 h-px bg-surface-700"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-800 border border-surface-700 text-surface-500 text-sm font-bold">2</div>
              <div class="flex-1 h-px bg-surface-700"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-800 border border-surface-700 text-surface-500 text-sm font-bold">3</div>
            </div>
            <p class="text-center text-xs text-surface-500 -mt-6 mb-8">Payment Instructions - Submit Proof - Confirmation</p>

            <!-- Order Summary -->
            <div class="p-5 rounded-xl bg-white/[0.03] border border-surface-600/15 mb-8">
              <h3 class="text-sm font-bold text-surface-500 tracking-widest uppercase mb-4">Order Summary</h3>
              <div class="flex items-start gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-xl border border-primary-500/10 shrink-0">
                  {service.icon}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-base font-bold text-surface-100">{service.title}</p>
                  <p class="text-sm text-surface-500 mt-0.5">{service.timeline}</p>
                  <p class="text-xs text-surface-600 mt-1">{paymentTypeDisplay}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-2xl font-black text-surface-100">${'$'}{price}</p>
                  <p class="text-xs text-surface-500">{priceLabel}</p>
                </div>
              </div>
            </div>

            <!-- Payment Methods -->
            <div class="mb-8">
              <label class="flex items-center gap-2 mb-3">
                <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                <span class="text-sm font-bold text-surface-300">Send Payment To</span>
              </label>

              <div class="space-y-4">
                {manualPaymentMethods.map((method) => (
                  <div class="p-5 rounded-xl bg-white/[0.02] border border-surface-600/15">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-xl">{method.icon}</span>
                      <div class="flex-1">
                        <span class="text-sm font-bold text-surface-200">{method.name}</span>
                      </div>
                      <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full border text-${method.regionColor}-400 bg-${method.regionColor}-400/10 border-${method.regionColor}-400/15`}>{method.region}</span>
                    </div>

                    <div class="space-y-2 mb-3">
                      {method.details.map((detail) => (
                        <div class="flex items-start gap-3">
                          <span class="text-xs text-surface-500 w-28 shrink-0 pt-0.5 sm:w-36">{detail.label}</span>
                          <span class="text-sm font-mono text-surface-300 select-all break-all">{detail.value}</span>
                        </div>
                      ))}
                    </div>

                    {method.note && (
                      <div class="flex items-start gap-2 p-2.5 rounded-lg bg-surface-800/40">
                        <svg class="w-3.5 h-3.5 text-warning-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span class="text-xs text-surface-500">{method.note}</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            <!-- How it works -->
            <div class="p-5 rounded-xl bg-accent-500/5 border border-accent-500/10 mb-8">
              <h4 class="text-sm font-bold text-accent-400 mb-3">How Manual Payment Works</h4>
              <ol class="space-y-2.5">
                {[
                  'Choose a payment method above and send the exact amount',
                  'Keep your payment receipt, TrxID, or confirmation screenshot',
                  'Click "I\'ve Completed Payment" below to submit your proof',
                  'We\'ll verify your payment and respond within 24 hours',
                ].map((step, i) => (
                  <li class="flex items-start gap-2.5 text-sm text-surface-400">
                    <span class="flex h-5 w-5 items-center justify-center rounded-full bg-accent-500/10 text-accent-400 text-xs font-bold shrink-0 mt-0.5">{i + 1}</span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </div>

            <!-- Proceed Button -->
            <button
              @click="goToConfirm()"
              class="btn-glow flex items-center justify-center gap-3 w-full rounded-xl px-6 py-4 text-base font-semibold bg-primary-600 hover:bg-primary-500 text-white transition-all duration-200 cursor-pointer shadow-lg shadow-primary-600/20"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              I've Completed the Payment
            </button>

            <p class="text-xs text-surface-600 text-center mt-4">
              Already paid? Click above to submit your payment proof for verification.
            </p>
          </div>
        </div>
      </div>

      <!-- ==========================================
           STEP 2: SUBMIT PAYMENT PROOF
           ========================================== -->
      <div x-show="step === 'confirm'" x-cloak
        x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
        <div class="glass-card rounded-2xl overflow-hidden">
          <div class="h-0.5 bg-gradient-to-r from-accent-500 via-primary-500 to-accent-500"></div>
          <div class="p-8 sm:p-10">

            <!-- Progress -->
            <div class="flex items-center gap-3 mb-8">
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-accent-600 text-white text-sm font-bold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div class="flex-1 h-px bg-accent-600"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-accent-600 text-white text-sm font-bold">2</div>
              <div class="flex-1 h-px bg-surface-700"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-800 border border-surface-700 text-surface-500 text-sm font-bold">3</div>
            </div>

            <div class="text-center mb-8">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-accent-500/10 border border-accent-500/15 mb-4">
                <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              </div>
              <h2 class="text-2xl font-black text-surface-100">Submit Payment Proof</h2>
              <p class="text-sm text-surface-400 mt-2">Fill in your details below so we can verify your payment.</p>
            </div>

            <!-- Quick summary -->
            <div class="p-4 rounded-xl bg-white/[0.02] border border-surface-600/10 mb-8 flex items-center gap-4">
              <span class="text-2xl">{service.icon}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-surface-200">{service.title}</p>
                <p class="text-xs text-surface-500">${'$'}{price} {priceLabel} · Manual Payment</p>
              </div>
              <button
                @click="goToInstructions()"
                class="shrink-0 text-xs font-semibold text-primary-400 hover:text-primary-300 underline underline-offset-2 transition-colors cursor-pointer"
              >
                View Instructions
              </button>
            </div>

            <!-- Transaction Form -->
            <div class="space-y-5">
              <!-- Payment Method -->
              <div>
                <label for="pay-method" class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                  <span class="text-sm font-medium text-surface-300">Payment Method Used <span class="text-red-400">*</span></span>
                </label>
                <select id="pay-method" x-model="form.method"
                  class="w-full px-4 py-3 rounded-xl bg-surface-900/50 border border-surface-600/40 text-sm text-surface-200 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/20 transition-all cursor-pointer appearance-none"
                  style="background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='%236b7280'%3E%3Cpath fill-rule='evenodd' d='M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z' clip-rule='evenodd' /%3E%3C/svg%3E&quot;); background-position: right 0.75rem center; background-repeat: no-repeat; background-size: 1rem;">
                  <template x-for="m in methods" :key="m.code">
                    <option :value="m.code" x-text="m.icon + '  ' + m.name + ' (' + m.region + ')'"></option>
                  </template>
                </select>
              </div>

              <!-- Name -->
              <div>
                <label for="pay-name" class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  <span class="text-sm font-medium text-surface-300">Full Name <span class="text-red-400">*</span></span>
                </label>
                <input
                  id="pay-name"
                  type="text"
                  x-model="form.name"
                  placeholder="Your full name"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-900/50 border border-surface-600/40 text-sm text-surface-200 placeholder-surface-600 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/20 transition-all"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="pay-email" class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  <span class="text-sm font-medium text-surface-300">Email Address <span class="text-red-400">*</span></span>
                </label>
                <input
                  id="pay-email"
                  type="email"
                  x-model="form.email"
                  placeholder="your@email.com"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-900/50 border border-surface-600/40 text-sm text-surface-200 placeholder-surface-600 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/20 transition-all"
                />
                <p class="text-xs text-surface-600 mt-1.5">A confirmation will be sent to this email address.</p>
              </div>

              <!-- Transaction ID -->
              <div>
                <label for="pay-trx" class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" /></svg>
                  <span class="text-sm font-medium text-surface-300">Transaction ID / Reference <span class="text-red-400">*</span></span>
                </label>
                <input
                  id="pay-trx"
                  type="text"
                  x-model="form.trxId"
                  placeholder="e.g. TXN123ABC, bKash TrxID, or bank reference"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-900/50 border border-surface-600/40 text-sm text-surface-200 placeholder-surface-600 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/20 transition-all font-mono"
                />
                <p class="text-xs text-surface-600 mt-1.5">Find this in your payment confirmation, bank app, or bKash SMS.</p>
              </div>

              <!-- Note -->
              <div>
                <label for="pay-note" class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-surface-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                  <span class="text-sm font-medium text-surface-300">Additional Note <span class="text-surface-600">(optional)</span></span>
                </label>
                <textarea
                  id="pay-note"
                  x-model="form.note"
                  rows="3"
                  placeholder="Any message or special instructions..."
                  class="w-full px-4 py-3 rounded-xl bg-surface-900/50 border border-surface-600/40 text-sm text-surface-200 placeholder-surface-600 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/20 transition-all resize-none"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                @click="submitTrx()"
                :disabled="submitting || !form.name || !form.email || !form.trxId"
                :class="(form.name && form.email && form.trxId) ? 'bg-accent-600 hover:bg-accent-500 text-white cursor-pointer shadow-lg shadow-accent-600/20' : 'bg-surface-700/50 text-surface-500 cursor-not-allowed'"
                class="flex items-center justify-center gap-3 w-full rounded-xl px-6 py-4 text-base font-semibold transition-all duration-200"
              >
                <template x-if="submitting">
                  <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </template>
                <template x-if="!submitting">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                </template>
                <span x-text="submitting ? 'Submitting...' : 'Submit Payment Confirmation'"></span>
              </button>

              <p class="text-xs text-surface-600 text-center">
                Your payment proof will be sent to <span class="text-surface-400">{siteData.email}</span> for verification.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- ==========================================
           STEP 3: SUCCESS
           ========================================== -->
      <div x-show="step === 'success'" x-cloak
        x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
        <div class="glass-card rounded-2xl overflow-hidden">
          <div class="h-0.5 bg-gradient-to-r from-success-400 via-accent-400 to-success-400"></div>
          <div class="p-8 sm:p-10 text-center">

            <!-- Progress -->
            <div class="flex items-center gap-3 mb-8">
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-accent-600 text-white text-sm font-bold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div class="flex-1 h-px bg-accent-600"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-accent-600 text-white text-sm font-bold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div class="flex-1 h-px bg-accent-600"></div>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-success-500 text-white text-sm font-bold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
              </div>
            </div>

            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-success-500/10 border border-success-500/15 mb-6">
              <svg class="w-10 h-10 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>

            <h2 class="text-2xl sm:text-3xl font-black text-surface-100 mb-2">Payment Submitted!</h2>
            <p class="text-surface-400 max-w-md mx-auto mb-8">
              Your payment proof has been sent successfully. We'll verify it and respond within 24 hours.
            </p>

            <!-- Reference Card -->
            <div class="p-6 rounded-xl bg-white/[0.03] border border-surface-600/15 text-left mb-8">
              <h3 class="text-xs font-bold text-surface-500 tracking-widest uppercase mb-4">Submission Summary</h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Reference</span>
                  <span class="text-sm font-mono font-bold text-primary-400" x-text="reference"></span>
                </div>
                <div class="h-px bg-surface-700/50"></div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Service</span>
                  <span class="text-sm text-surface-200 font-medium">{service.title}</span>
                </div>
                <div class="h-px bg-surface-700/50"></div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Amount</span>
                  <span class="text-sm text-surface-200 font-medium">${'$'}{price} {priceLabel}</span>
                </div>
                <div class="h-px bg-surface-700/50"></div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Payment Method</span>
                  <span class="text-sm text-surface-200 font-medium" x-text="selectedMethodName()"></span>
                </div>
                <div class="h-px bg-surface-700/50"></div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Transaction ID</span>
                  <span class="text-sm font-mono text-surface-200" x-text="form.trxId"></span>
                </div>
                <div class="h-px bg-surface-700/50"></div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-surface-400">Submitted To</span>
                  <span class="text-sm text-surface-200">{siteData.email}</span>
                </div>
              </div>
            </div>

            <div class="p-4 rounded-xl bg-warning-500/5 border border-warning-500/10 mb-8">
              <p class="text-sm text-surface-400">
                <span class="text-warning-400 font-bold">Important:</span> Save the reference number above. If you don't hear back within 24 hours, contact us directly at <a href="mailto:{siteData.email}" class="text-primary-400 hover:text-primary-300 underline underline-offset-2">{siteData.email}</a>.
              </p>
            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a
                href="/"
                class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary-600 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-500"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                Back to Home
              </a>
              <a
                href="mailto:{siteData.email}?subject=Payment%20Verification%20-%20{encodeURIComponent(service.title)}"
                class="inline-flex items-center justify-center gap-2 rounded-xl border border-surface-600/30 px-6 py-3 text-sm font-semibold text-surface-300 transition-all hover:border-primary-500/30 hover:text-primary-400"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Email Us Directly
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
